{
  "name": "echo-agent",
  "version": "0.1.0",
  "description": "An AI agent with portable, encrypted, Filecoin-anchored memory — powered by Echo. Built for FilecoinTLDR Builder Challenge Cycle 2.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "demo:switch": "tsx src/index.ts --demo=switch",
    "demo:save": "tsx src/index.ts --demo=save",
    "demo:load": "tsx src/index.ts --demo=load"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@filoz/synapse-sdk": "^1.0.1",
    "@lighthouse-web3/sdk": "^0.4.6",
    "ai": "^4.0.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.17.0",
    "viem": "^2.54.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18"
  }
}
